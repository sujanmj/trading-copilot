# Optional local overrides — Railway env vars take precedence in production
# For local laptop mode see config/local.env.example and run: python run_local.py
API_BASE_URL=http://127.0.0.1:8080
API_KEY=

# Local laptop mode (ignored on Railway unless explicitly set)
LOCAL_DEV_MODE=0
LOCAL_ONLY=0
DISABLE_TELEGRAM=0
DISABLE_TELEGRAM_LISTENER=0
DISABLE_TELEGRAM_SENDS=0
DISABLE_RAILWAY_API=0

# AI — Claude strategist (premium synthesis only)
ANTHROPIC_API_KEY=

# AI — Gemini pool (intelligence engine)
GOOGLE_API_KEY_1=
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# AI — Groq pool (conversational / Telegram Q&A)
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Broker (optional)
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PIN=
ANGEL_TOTP_SECRET=

# YouTube tracker (optional)
YOUTUBE_API_KEY=

# Server (Railway sets PORT automatically)
PORT=8080
HOST=0.0.0.0
