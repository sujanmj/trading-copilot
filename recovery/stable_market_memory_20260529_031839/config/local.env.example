# Local laptop mode — copy to config/local.env or export before run_local.py
# Railway production ignores these unless explicitly set in the Railway dashboard.

LOCAL_DEV_MODE=1
LOCAL_ONLY=1

# Local FastAPI bind + GUI target
HOST=127.0.0.1
PORT=8080
API_BASE_URL=http://127.0.0.1:8080

# Disable all Telegram activity (listener, sends, api.telegram.org)
DISABLE_TELEGRAM=1
DISABLE_TELEGRAM_LISTENER=1
DISABLE_TELEGRAM_SENDS=1

# Prevent GUI/backend from preferring Railway remote API
DISABLE_RAILWAY_API=1

# Optional local test hooks
# LOCAL_FORCE_EOD=1
# DISABLE_SCHEDULER=0
